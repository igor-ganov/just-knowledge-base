---
import '../ui/tokens.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>jkb workbench</title>
    <style>
      .wb {
        display: grid;
        grid-template-columns: 14rem 18rem 1fr;
        height: 100dvh;
      }
      .wb > * {
        overflow-y: auto;
        padding: 1rem;
        box-sizing: border-box;
      }
      .wb nav {
        border-right: 1px solid var(--color-border);
        background: var(--color-bg-raised);
      }
      .wb .controls {
        border-right: 1px solid var(--color-border);
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }
      .wb button.entry {
        display: block;
        width: 100%;
        text-align: left;
        padding: 0.4rem 0.6rem;
        border: none;
        background: none;
        color: var(--color-text);
        border-radius: 6px;
        cursor: pointer;
      }
      .wb button.entry[aria-pressed='true'] {
        background: var(--color-accent-soft);
        color: var(--color-accent-strong);
      }
      .wb label {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        font-size: 0.85rem;
      }
      .wb input,
      .wb select {
        padding: 0.35rem;
        border: 1px solid var(--color-border);
        border-radius: 6px;
        background: var(--color-bg);
        color: var(--color-text);
      }
      .wb .host {
        background: var(--color-bg);
      }
      .wb h1 {
        font-size: 1rem;
        margin: 0 0 0.75rem;
      }
      .wb p.desc {
        color: var(--color-text-muted);
        font-size: 0.85rem;
        margin: 0 0 0.5rem;
      }
    </style>
  </head>
  <body>
    <div class="wb">
      <nav aria-label="Components"><h1>Workbench</h1></nav>
      <div class="controls" aria-label="Props"></div>
      <div class="host" aria-label="Preview"></div>
    </div>
    <script>
      import { workbenchEntries, type WorkbenchEntry } from '../workbench/registry';

      const nav = document.querySelector('.wb nav');
      const controlsHost = document.querySelector('.wb .controls');
      const previewHost = document.querySelector('.wb .host');

      const state: { entry: WorkbenchEntry; props: Record<string, unknown> } = {
        entry: workbenchEntries[0]!,
        props: { ...workbenchEntries[0]!.defaults },
      };

      const remount = (): void => {
        if (previewHost instanceof HTMLElement) state.entry.mount(previewHost, state.props);
      };

      const renderControls = (): void => {
        if (!(controlsHost instanceof HTMLElement)) return;
        controlsHost.replaceChildren();
        const description = document.createElement('p');
        description.className = 'desc';
        description.textContent = state.entry.description;
        controlsHost.append(description);
        for (const control of state.entry.controls) {
          const label = document.createElement('label');
          label.textContent = control.label;
          const input =
            control.kind === 'select' ? document.createElement('select') : document.createElement('input');
          if (input instanceof HTMLSelectElement) {
            for (const option of control.options ?? []) {
              const element = document.createElement('option');
              element.value = option;
              element.textContent = option;
              input.append(element);
            }
            input.value = String(state.props[control.key] ?? '');
          } else if (control.kind === 'boolean') {
            input.type = 'checkbox';
            input.checked = state.props[control.key] === true;
          } else {
            input.type = 'text';
            input.value = String(state.props[control.key] ?? '');
          }
          input.addEventListener('input', () => {
            state.props[control.key] =
              control.kind === 'boolean' && input instanceof HTMLInputElement ? input.checked : input.value;
            remount();
          });
          label.append(input);
          controlsHost.append(label);
        }
      };

      const renderNav = (): void => {
        if (!(nav instanceof HTMLElement)) return;
        for (const entry of workbenchEntries) {
          const button = document.createElement('button');
          button.className = 'entry';
          button.textContent = entry.name;
          button.setAttribute('aria-pressed', entry === state.entry ? 'true' : 'false');
          button.addEventListener('click', () => {
            state.entry = entry;
            state.props = { ...entry.defaults };
            for (const other of nav.querySelectorAll('button.entry')) {
              other.setAttribute('aria-pressed', other === button ? 'true' : 'false');
            }
            renderControls();
            remount();
          });
          nav.append(button);
        }
      };

      renderNav();
      renderControls();
      remount();
    </script>
  </body>
</html>
